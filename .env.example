# Discord OAuth — https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# URL exacte autorisée dans le portail Discord (prod : https://ton-site.vercel.app/api/auth/discord/callback)
# Local (npm run dev) : http://localhost:5173/api/auth/discord/callback
DISCORD_REDIRECT_URI=

# Secret aléatoire long pour signer le cookie de session (ex. openssl rand -hex 32)
AUTH_JWT_SECRET=

# Pronostics MRM : URL de base du backend utilisée uniquement côté serveur/proxy.
# Le navigateur appelle toujours des routes relatives `/api/...`.
# En local, `npm run dev` utilise `vite-dev-api-plugin.js` pour proxyfier ces routes.
# En production, les routes `/api/*` (serverless) font aussi le relais vers ce backend.
# Ex: https://back.mcsr-game.com
# (le proxy ajoute automatiquement /api si absent)
# BACKEND_API_BASE_URL=https://back.mcsr-game.com
